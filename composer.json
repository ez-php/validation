{
  "name": "ez-php/validation",
  "version": "0.1.0",
  "description": "Validation module for the ez-php framework — rule-based validator with database-backed unique/exists rules and optional i18n support",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["validation", "validator", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/validation",
  "support": {
    "issues": "https://github.com/ez-php/validation/issues",
    "source": "https://github.com/ez-php/validation"
  },
  "require": {
    "php": "^8.5",
    "ez-php/framework": "0.*"
  },
  "suggest": {
    "ez-php/i18n": "Enables localised validation error messages"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "ez-php/i18n": "0.*"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Validation\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
